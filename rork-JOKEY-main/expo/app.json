{
  "expo": {
    "name": "Jokey",
    "slug": "azbb4413e811lknfmyslw",
    "version": "1.13",
    "orientation": "portrait",
    "icon": "./assets/images/icon.jpeg",
    "scheme": "rork-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "autolinking": {
      "android": {
        "exclude": ["expo-location"]
      },
      "ios": {
        "exclude": ["expo-location"]
      }
    },
    "splash": {
      "image": "./assets/images/splash-icon.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.rork.azbb4413e811lknfmyslw",
      "buildNumber": "13",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Jokey needs microphone access to record audio jokes and videos.",
        "NSCameraUsageDescription": "Jokey needs camera access to record video jokes.",
        "NSPhotoLibraryUsageDescription": "Jokey needs photo library access to set your profile avatar."
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          }
        ]
      }
    },
    "android": {
      "versionCode": 13,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.jpeg",
        "backgroundColor": "#ffffff"
      },
      "package": "app.rork.azbb4413e811lknfmyslw",
      "blockedPermissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-audio",
      [
        "expo-image-picker",
        {
          "photosPermission": "Jokey needs photo library access to set your profile avatar."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Jokey utilise la caméra pour enregistrer vos vidéos.",
          "microphonePermission": "Jokey utilise le micro pour enregistrer le son de vos vidéos."
        }
      ],
      "./plugins/withEmbedDebugBundle.js",
      "./plugins/withAndroidUploadSigning.js",
      "./plugins/withRemoveForegroundServices.js"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
