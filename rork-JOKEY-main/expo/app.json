{
  "expo": {
    "name": "Jokey",
    "slug": "azbb4413e811lknfmyslw",
    "version": "1.14",
    "orientation": "portrait",
    "icon": "./assets/images/icon.jpeg",
    "scheme": "rork-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "autolinking": {
      "android": {
        "exclude": [
          "expo-location",
          "react-native-maps",
          "expo-notifications"
        ]
      },
      "ios": {
        "exclude": [
          "expo-location",
          "react-native-maps",
          "expo-notifications"
        ]
      }
    },
    "locales": {
      "en": "./locales/en.json",
      "fr": "./locales/fr.json",
      "ar": "./locales/ar.json"
    },
    "splash": {
      "image": "./assets/images/splash-icon.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.rork.azbb4413e811lknfmyslw",
      "buildNumber": "14",
      "infoPlist": {
        "CFBundleLocalizations": [
          "en",
          "fr",
          "ar"
        ],
        "CFBundleDevelopmentRegion": "en",
        "NSMicrophoneUsageDescription": "Jokey uses your microphone to record audio jokes and video sound. For example, when you tap Record, your voice is captured and published as a joke for the community.",
        "NSCameraUsageDescription": "Jokey uses your camera to record video jokes. For example, when you record a video joke, the footage is saved and shared on your Jokey profile for other users to watch.",
        "NSPhotoLibraryUsageDescription": "Jokey accesses your photo library so you can choose a profile picture. For example, the photo you select will be displayed on your public profile for other users to see."
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ]
      }
    },
    "android": {
      "versionCode": 14,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.jpeg",
        "backgroundColor": "#ffffff"
      },
      "package": "app.rork.azbb4413e811lknfmyslw",
      "blockedPermissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-audio",
      [
        "expo-image-picker",
        {
          "photosPermission": "Jokey accesses your photo library so you can choose a profile picture. For example, the photo you select will be displayed on your public profile for other users to see."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Jokey uses your camera to record video jokes. For example, when you record a video joke, the footage is saved and shared on your Jokey profile for other users to watch.",
          "microphonePermission": "Jokey uses your microphone to record audio jokes and video sound. For example, when you tap Record, your voice is captured and published as a joke for the community."
        }
      ],
      "expo-video",
      "./plugins/withEmbedDebugBundle.js",
      "./plugins/withAndroidUploadSigning.js",
      "./plugins/withRemoveForegroundServices.js",
      "expo-sqlite",
      "expo-secure-store",
      "expo-localization",
      "expo-mail-composer",
      "expo-tracking-transparency",
      [
        "expo-build-properties",
        {
          "ios": {
            "buildReactNativeFromSource": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
