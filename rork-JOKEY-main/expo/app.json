{
  "expo": {
    "name": "Jokey",
    "slug": "azbb4413e811lknfmyslw",
    "version": "1.4",
    "orientation": "portrait",
    "icon": "./assets/images/icon.jpeg",
    "scheme": "rork-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "autolinking": {
      "android": {
        "exclude": ["expo-location"]
      },
      "ios": {
        "exclude": ["expo-location"]
      }
    },
    "splash": {
      "image": "./assets/images/splash-icon.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.rork.azbb4413e811lknfmyslw"
    },
    "android": {
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.jpeg",
        "backgroundColor": "#ffffff"
      },
      "package": "app.rork.azbb4413e811lknfmyslw",
      "blockedPermissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-audio",
      "./plugins/withEmbedDebugBundle.js",
      "./plugins/withAndroidUploadSigning.js"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
